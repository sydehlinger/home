# Google OAuth 2.0 — from your Google Cloud project
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_me

# Comma-separated list of Google emails allowed to sign in.
# Optional in dev; REQUIRED in production (server will refuse to boot without it).
ALLOWED_EMAILS=you@example.com

# Where the React client is served from. Used for CORS and as the post-login redirect.
CLIENT_ORIGIN=http://localhost:5173

# Server port
PORT=3001

# Set to "production" in deployed environments. Forces secure cookies and ALLOWED_EMAILS.
NODE_ENV=development

# Override cookie.secure independently (e.g. dev behind HTTPS tunnel). Defaults to true in prod.
# COOKIE_SECURE=true

# Postgres connection string. Required.
# Local: postgres://user:pass@localhost:5432/home
# Render: copy the External Database URL from the Render dashboard.
DATABASE_URL=postgres://localhost:5432/home

# Override SSL behavior:
#   (unset)    = SSL with self-signed cert acceptance in prod, no SSL in dev
#   "disable"  = no SSL (use for local Postgres)
#   "strict"   = SSL with strict cert verification
# DATABASE_SSL=disable
